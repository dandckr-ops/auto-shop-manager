# Copy this file to .env.sso on the sandbox and fill in real values.

# Public hostname where the shop app will be available.
# Example: https://shop.example.com
SHOP_PUBLIC_URL=https://shop.squidhut.com

# Existing Keycloak issuer URL.
# Example: https://auth.example.com/realms/shop
OIDC_ISSUER_URL=

# Keycloak client for oauth2-proxy.
# Redirect URI in Keycloak must be:
#   https://shop.example.com/oauth2/callback
OIDC_CLIENT_ID=auto-shop-manager
OIDC_CLIENT_SECRET=

# Generate with:
#   openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=

# Limit access to specific email addresses or domains.
# Use "*" while testing only.
OAUTH2_PROXY_EMAIL_DOMAINS=*

# Cloudflare tunnel token from Zero Trust dashboard.
# Leave empty if you manage cloudflared outside this Compose project.
CLOUDFLARED_TUNNEL_TOKEN=

# Database settings. Set a strong password in .env.sso.
POSTGRES_DB=autoshop
POSTGRES_USER=autoshop
POSTGRES_PASSWORD=

# SMTP email settings for sending estimates.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
